{
  "manifest_version": 3,
  "name": "Jarvis Job Crawler",
  "version": "1.0.0",
  "description": "대기업/빅테크 채용공고 자동 수집 → Discord 전송",

  "permissions": [
    "alarms",
    "tabs",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:7779/*",
    "https://www.skcareers.com/*",
    "https://career.hyundai-autoever.com/*",
    "https://krafton.com/*",
    "https://careers.navercorp.com/*",
    "https://recruit.navercorp.com/*",
    "https://careers.krafton.com/*",
    "https://toss.im/*",
    "https://about.daangn.com/*",
    "https://career.woowahan.com/*",
    "https://www.lgcns.com/*",
    "https://recruit.kt.com/*",
    "https://www.samsungsds.com/*",
    "https://careers.samsung.com/*",
    "https://recruit.hanwhasystems.com/*",
    "https://careers.linecorp.com/*",
    "https://www.coupang.jobs/*",
    "https://careers.dunamu.com/*",
    "https://careers.yanolja.co/*",
    "https://career.kurly.com/*",
    "https://careers.nhn.com/*",
    "https://career.nexon.com/*",
    "https://career.netmarble.net/*",
    "https://careers.ncsoft.com/*",
    "https://talent.hyundaicard.com/*",
    "https://careers.lguplus.com/*",
    "https://www.poscodx.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Jarvis Job Crawler"
  },

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
