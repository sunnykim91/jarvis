# Jarvis Infra .env 설정 파일
# 복사 후 값 채우기: cp .env.example .env

# ===== 필수 =====
DISCORD_TOKEN=your_discord_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== Discord 서버 설정 =====
GUILD_ID=your_discord_guild_id
# 봇이 응답할 채널 ID (쉼표 구분)
CHANNEL_ID=your_default_channel_id
CHANNEL_IDS=channel_id1,channel_id2
# 재시작 알림 제외 채널 (쉼표 구분, 선택)
QUIET_CHANNEL_IDS=
# 가족 채널 (쉼표 구분, 선택)
FAMILY_CHANNEL_IDS=
# 라이트 모드 채널 (선택)
LITE_CHANNEL_ID=
# 마켓 알림 채널 (선택)
MARKET_CHANNEL_ID=
# 시스템 알림 채널 (선택)
SYSTEM_ALERT_CHANNEL_ID=
# 오너 전용 알림 채널 (선택)
OWNER_ALERT_CHANNEL_ID=

# ===== Discord 사용자 설정 =====
OWNER_DISCORD_ID=your_discord_user_id
OWNER_NAME=Owner
OWNER_TITLE=Owner
FAMILY_DISCORD_ID=
FAMILY_CHANNEL_ID=
FAMILY_USER_ID=
FAMILY_MEMBER_NAME=

# ===== 봇 페르소나 설정 =====
BOT_NAME=Jarvis
BOT_LOCALE=ko
BOT_HOME=/path/to/.jarvis

# ===== 외부 서비스 =====
OPENAI_API_KEY=
GITHUB_USERNAME=
CLAUDE_BINARY=~/.local/bin/claude

# ===== 알림 서비스 (선택) =====
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# ===== 추론 설정 (선택) =====
# Anthropic API 지역 라우팅 (예: us, eu)
INFERENCE_GEO=

# ===== 기타 =====
NODE_ENV=production
