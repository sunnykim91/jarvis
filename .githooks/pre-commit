#!/usr/bin/env bash
# Privacy Guard pre-commit hook (Phase 1)
# 단일 스캐너(scripts/privacy/scan.mjs) 호출만 담당.
#
# 이전 버전(secret 패턴 in-line grep)은 git history 에서 참조:
#   git log -p -- .githooks/pre-commit
# Secret 탐지는 .gitleaks.toml + CI(pii-scan.yml)가 담당.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

if ! command -v node >/dev/null 2>&1; then
  echo "⚠️  node 없음 — privacy scan skip (경고만)" >&2
  exit 0
fi

if [ -n "${PRIVACY_BYPASS_REASON:-}" ]; then
  echo "⚠️  Privacy scan bypassed: $PRIVACY_BYPASS_REASON" >&2
  # TODO Phase 3: ledger 기록 (~/.jarvis/logs/privacy-bypass.jsonl)
  exit 0
fi

node "$ROOT/scripts/privacy/scan.mjs" --staged
