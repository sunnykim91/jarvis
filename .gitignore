.DS_Store
node_modules/
__pycache__/
*.pyc

# ═══════════════════════════════════════════════════════════════════════
# A2 Runtime — ~/jarvis/runtime/ 은 100% private.
# Git 공식: parent dir 제외 시 하위 negation 불가. 따라서 /runtime/* 로
# 파일만 exclude + !negation 허용. README.md/.gitkeep만 tracked.
# ═══════════════════════════════════════════════════════════════════════
/runtime/*
!/runtime/.gitkeep
!/runtime/README.md

# Private data (personal configs, secrets, overrides)
private/
!private/README.md

# Local IDE/LSP caches (may contain personal context)
.serena/
.vscode/
.idea/

# RAG data (user-specific)
*.lance/
index-state.json
access-log.json
rag-errors.jsonl
write.lock

# Infra runtime data
infra/config/user-schedule.json
infra/.env
infra/discord/node_modules/
infra/discord/.env
infra/discord/personas.json
infra/config/secrets/
infra/config/tasks.json
infra/config/goals.json
infra/config/effective-tasks.json

# Root config — username 노출 방지 (tracked 상태였으나 2026-04-17 제거)
/config/
/docker-compose.yml
/wiki/
infra/config/company-dna.md
infra/config/jira.env
infra/config/tutoring.env
infra/config/google-calendar-token.json
infra/config/user_profiles.json
infra/config/discord-channels.json
infra/config/discord-mcp.json

# ═══════════════════════════════════════════════════════════════════════
# Runtime home (통합 후 개인 데이터 보호 — 절대 git에 올라가면 안 됨)
# ═══════════════════════════════════════════════════════════════════════

# State (세션, 토큰 레저, 에러 로그, 포트폴리오, 봇 PID 등)
state/
# Logs (모든 실행 로그)
logs/
# Wiki (개인 지식 베이스 — career, family, health, ops 등)
wiki/
# Context (대화 이력, 사용자 메모리, Claude 세션)
context/
# Docker (Langfuse + 크레덴셜)
docker/
# Board (Jarvis Board 로컬 인스턴스)
board/
# Results (크론 태스크 결과물)
results/
# Reports (생성된 리포트)
reports/
# Backup (시스템 백업)
backup/
# Watchdog (워치독 상태)
watchdog/
# Inbox (수신 항목)
inbox/
# Teams (팀 상태)
teams/
# Experiments
experiments/
# Vault
vault-starter/
# Tmp
tmp/
# Data (런타임 데이터)
data/

# 개인 설정 (webhook URL, 토큰, API 키)
*.env
!*.env.example
!*.env.test
# runtime/.env.test 는 실제 시크릿 가능성 — 글로벌 !*.env.test negation 덮어쓰기
runtime/.env.test
runtime/discord/.env
infra/config/monitoring.json
infra/config/models.json
config/*.bak*
*.backup

# JSONL 원장 (토큰, 에러, 커밋먼트 등)
*.jsonl
!*.example.jsonl

# Personal scripts (가족 멤버 전용, 개인 설정)
infra/scripts/boram-*.sh
infra/scripts/_boram_*.py
infra/scripts/board-auto-deploy.sh
infra/scripts/relay-to-owner.sh
infra/scripts/opensync.py
infra/scripts/setup_infra.py
infra/scripts/setup_rag.py

# Runtime
.jarvis.pid
jarvis.log
infra/office/node_modules
infra/office/dist

# Chrome Extension (오너 개인 프로토타입 — 사이트 목록/파서에 PII 결합)
# README.md 만 공개 유지, 나머지는 private 관리
infra/chrome-extension/*
!infra/chrome-extension/README.md

# Claude Code worktrees
.claude/worktrees/

# Archive directories (PII 정리 과정에서 이관된 구파일 — 절대 tracked 금지)
_archive-*/
